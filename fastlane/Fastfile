default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    # Headless auth via App Store Connect API key — no 2FA prompt
    api_key = app_store_connect_api_key(
      key_id: "5264UM4QX6",
      issuer_id: "ff8d29fe-542a-4cbb-aec1-5214e7276d4c",
      key_filepath: File.expand_path("AuthKey_5264UM4QX6.p8", __dir__),
      in_house: false
    )

    # Use Unix timestamp as build number — unique every second, no versioning setup needed
    build_number = Time.now.to_i.to_s

    # Ensure automatic code signing is active
    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: "44JDRP3T56",
      bundle_identifier: "ddy.WifiLens"
    )

    build_app(
      scheme: "WifiLens",
      export_method: "app-store",
      clean: true,
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number} -allowProvisioningUpdates",
      export_xcargs: "-allowProvisioningUpdates",
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        teamID: "44JDRP3T56"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

end
